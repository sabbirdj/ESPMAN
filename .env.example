# ============================================================================
#  ESP Device Manager — Environment Variables
# ============================================================================

# ---- Database (Turso / libSQL) ----
# DEVELOPMENT (local SQLite file — no Turso account needed):
DATABASE_URL=file:./db/custom.db

# PRODUCTION (Turso cloud — get these from your Turso dashboard):
#   1. Install Turso CLI:  curl -sSfL https://get.tur.so/install.sh | bash
#   2. Sign up:            turso auth signup
#   3. Create database:    turso db create esp-manager
#   4. Get URL:            turso db show esp-manager --url
#   5. Get token:          turso db tokens create esp-manager
#
# Then replace the above line with:
#   DATABASE_URL=libsql://esp-manager-<your-org>.turso.io
#   TURSO_AUTH_TOKEN=eyJhbGciOi...your-token-here...

# TURSO_AUTH_TOKEN is only needed when DATABASE_URL points to Turso (libsql://)
# Leave it empty for local development.
TURSO_AUTH_TOKEN=
